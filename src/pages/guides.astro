---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const guides = (await getCollection("guides")).sort(
  (a, b) => a.data.order - b.data.order,
);
const learning = (await getCollection("learning")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Layout title="Ръководства" description="Практични ръководства и кратки курсове за начинаещи и напреднали.">
  <main class="wrap page">
    <div class="kicker">Ръководства и обучение</div>
    <h1 class="page-title">
      Научи изкуствения интелект — на стъпки, без излишна теория
    </h1>
    <p class="page-lead">
      Практични ръководства и кратки курсове за начинаещи и напреднали. Всеки
      урок завършва с нещо, което можеш да приложиш веднага.
    </p>

    <div class="learning-grid">
      {
        learning.map((c) => (
          <article class="learn-card">
            <span class="learn-level">{c.data.level}</span>
            <h3 class="learn-title">{c.data.title}</h3>
            <p class="learn-desc">{c.data.description}</p>
            <span class="learn-meta">{c.data.meta}</span>
          </article>
        ))
      }
    </div>

    <div class="section-head no-link">
      <h2>Ръководства стъпка по стъпка</h2>
    </div>
    <div class="guide-list">
      {
        guides.map((g) => (
          <a href={`/guides/${g.id}`} class="guide-row" data-guide>
            <span class="guide-n">{String(g.data.order).padStart(2, "0")}</span>
            <span>
              <span class="guide-title">{g.data.title}</span>
              <span class="guide-meta">{g.data.meta}</span>
            </span>
            <span class="guide-arrow">→</span>
          </a>
        ))
      }
    </div>
  </main>
</Layout>

<style>
  .page {
    padding-top: 52px;
    padding-bottom: 80px;
  }
  .page-title {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 46px;
    letter-spacing: -0.02em;
    margin: 14px 0 12px;
    max-width: 18em;
  }
  .page-lead {
    font-family: var(--serif);
    font-size: 18px;
    color: var(--body);
    margin: 0 0 44px;
    max-width: 40em;
  }
  .learning-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 56px;
  }
  .learn-card {
    display: flex;
    flex-direction: column;
    background: var(--panel-cream);
    border: 1px solid var(--line);
    padding: 30px;
    min-height: 230px;
  }
  .learn-level {
    display: inline-block;
    align-self: flex-start;
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 4px 9px;
    margin-bottom: 20px;
  }
  .learn-title {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 25px;
    line-height: 1.16;
    color: var(--ink);
    margin: 0 0 14px;
  }
  .learn-desc {
    font-size: 14px;
    line-height: 1.55;
    color: var(--body-2);
    margin: 0 0 16px;
  }
  .learn-meta {
    margin-top: auto;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted);
  }
  .section-head.no-link {
    margin-bottom: 8px;
  }
  .guide-row {
    cursor: pointer;
    display: grid;
    grid-template-columns: 64px 1fr auto;
    gap: 24px;
    align-items: center;
    padding: 22px 8px;
    border-bottom: 1px solid var(--line);
    text-decoration: none;
  }
  .guide-row:hover .guide-title {
    color: var(--accent);
  }
  .guide-n {
    font-family: var(--serif);
    font-size: 30px;
    color: var(--accent);
    font-weight: 500;
  }
  .guide-title {
    display: block;
    font-family: var(--serif);
    font-weight: 600;
    font-size: 22px;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .guide-meta {
    display: block;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--muted-3);
    margin-top: 5px;
    text-transform: uppercase;
  }
  .guide-arrow {
    font-size: 22px;
    color: var(--ink);
  }
  @media (max-width: 900px) {
    .learning-grid {
      grid-template-columns: 1fr;
    }
    .page-title {
      font-size: 34px;
    }
  }
</style>
