---
import Layout from "../layouts/Layout.astro";
import SubscribeForm from "../components/SubscribeForm.astro";
import { SITE } from "../lib/site";

const stats = [
  { value: SITE.subscribers, label: "Абонати" },
  { value: String(SITE.issues), label: "Издадени броеве" },
  { value: "0%", label: "Спам, винаги" },
];

const benefits = [
  {
    n: "01",
    title: "Подбрани новини",
    desc: "Само важното от седмицата в ИИ — без да се давиш в безкраен поток от заглавия.",
  },
  {
    n: "02",
    title: "Ясни обяснения",
    desc: "Сложните теми, преведени на разбираем език, с примери от реалния живот.",
  },
  {
    n: "03",
    title: "Практични ръководства",
    desc: "Стъпка по стъпка как да използваш инструментите — за работа и за учене.",
  },
  {
    n: "04",
    title: "Учебни материали",
    desc: "Кратки курсове и речник, които изграждат знанието ти системно и спокойно.",
  },
];

const team = [
  {
    initials: "МК",
    name: "Мартин Колев",
    role: "Главен редактор",
    bio: "Журналист, пишещ за технологии от 2014 г. Превежда сложното на човешки език.",
  },
  {
    initials: "ИС",
    name: "Ива Стоянова",
    role: "Анализи и регулации",
    bio: "Следи политиките и етиката около ИИ в Европа и по света.",
  },
  {
    initials: "ПГ",
    name: "Петър Георгиев",
    role: "Ръководства и обучение",
    bio: "Създава учебните материали и курсовете на AI Академия.",
  },
];
---

<Layout title="За нас" description="AI Академия е независим седмичен бюлетин и библиотека с материали за изкуствения интелект.">
  <main>
    <section class="wrap intro">
      <div class="kicker">За нас</div>
      <h1 class="intro-title">
        Помагаме на хората в България да разберат изкуствения интелект —
        спокойно и без шум.
      </h1>
      <p class="intro-lead">
        AI Академия е независим седмичен бюлетин и библиотека с материали за
        изкуствения интелект. Превеждаме сложното на разбираем език и показваме
        как технологията може да е полезна в работата и ежедневието — без хайп и
        без страх.
      </p>
    </section>

    <section class="wrap stats-wrap">
      <div class="stats">
        {
          stats.map((s) => (
            <div class="stat">
              <div class="stat-value">{s.value}</div>
              <div class="stat-label">{s.label}</div>
            </div>
          ))
        }
      </div>
    </section>

    <section class="wrap block">
      <div class="section-head no-link">
        <h2>Какво получаваш</h2>
      </div>
      <div class="benefits">
        {
          benefits.map((b) => (
            <div class="benefit">
              <div class="benefit-n">{b.n}</div>
              <div>
                <h3 class="benefit-title">{b.title}</h3>
                <p class="benefit-desc">{b.desc}</p>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section class="wrap block">
      <div class="section-head no-link">
        <h2>Екипът</h2>
      </div>
      <div class="team">
        {
          team.map((t) => (
            <div class="member">
              <div class="member-photo">
                <span>{t.initials}</span>
              </div>
              <h3 class="member-name">{t.name}</h3>
              <div class="member-role">{t.role}</div>
              <p class="member-bio">{t.bio}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section id="subscribe" class="cta">
      <div class="cta-inner">
        <h2 class="cta-title">Присъедини се към 14 000+ читатели.</h2>
        <p class="cta-text">
          Един имейл седмично. Безплатно. Откажи се по всяко време.
        </p>
        <div class="cta-form">
          <SubscribeForm compact />
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .intro {
    max-width: 840px;
    padding-top: 64px;
    padding-bottom: 40px;
  }
  .intro-title {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 48px;
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 18px 0 24px;
    text-wrap: balance;
  }
  .intro-lead {
    font-family: var(--serif);
    font-size: 20px;
    line-height: 1.6;
    color: var(--body);
    margin: 0;
  }
  .stats-wrap {
    max-width: 1080px;
    padding-top: 32px;
    padding-bottom: 32px;
  }
  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  .stat {
    background: var(--cream);
    padding: 30px 26px;
  }
  .stat-value {
    font-family: var(--serif);
    font-size: 42px;
    color: var(--accent);
    font-weight: 600;
  }
  .stat-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 6px;
  }
  .block {
    max-width: 1080px;
    padding-top: 44px;
    padding-bottom: 44px;
  }
  .section-head.no-link {
    margin-bottom: 28px;
  }
  .benefits {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 36px 48px;
  }
  .benefit {
    display: flex;
    gap: 18px;
  }
  .benefit-n {
    font-family: var(--serif);
    font-size: 22px;
    color: var(--accent);
    font-weight: 600;
    min-width: 32px;
  }
  .benefit-title {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 22px;
    margin: 0 0 8px;
    color: var(--ink);
  }
  .benefit-desc {
    font-size: 15px;
    line-height: 1.6;
    color: var(--body-2);
    margin: 0;
  }
  .team {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }
  .member-photo {
    aspect-ratio: 1 / 1;
    background: #e7decb;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }
  .member-photo span {
    font-family: var(--serif);
    font-size: 40px;
    font-weight: 600;
    color: #a99c84;
  }
  .member-name {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 21px;
    margin: 0 0 4px;
    color: var(--ink);
  }
  .member-role {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .member-bio {
    font-size: 14px;
    line-height: 1.6;
    color: var(--body-2);
    margin: 0;
  }
  .cta {
    background: var(--ink);
    color: var(--cream);
    margin-top: 24px;
  }
  .cta-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 68px 28px;
    text-align: center;
  }
  .cta-title {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 38px;
    line-height: 1.12;
    letter-spacing: -0.02em;
    margin: 0 0 14px;
  }
  .cta-text {
    font-size: 16px;
    color: #c9c0b0;
    margin: 0 0 26px;
  }
  .cta-form {
    max-width: 480px;
    margin: 0 auto;
  }
  @media (max-width: 900px) {
    .stats,
    .team,
    .benefits {
      grid-template-columns: 1fr;
    }
    .intro-title {
      font-size: 34px;
    }
  }
</style>
