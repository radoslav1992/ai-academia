---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const tools = (await getCollection("tools")).sort(
  (a, b) => a.data.order - b.data.order,
);

const categories = ["Всички", ...new Set(tools.map((t) => t.data.category))];

const pricingClass: Record<string, string> = {
  Безплатно: "free",
  Freemium: "freemium",
  Платено: "paid",
};
---

<Layout title="Инструменти" description="Директория с полезни инструменти за изкуствен интелект — подбрани и подредени по категория.">
  <main class="wrap page">
    <div class="kicker">Директория</div>
    <h1 class="page-title">Полезни ИИ инструменти</h1>
    <p class="page-lead">
      Подбрана директория с инструменти за изкуствен интелект — разпределени по
      категория и цена. Отбелязали сме кои работят добре на български.
    </p>

    <div class="filters" id="filters">
      {
        categories.map((c, i) => (
          <button
            class:list={["filter-btn", { active: i === 0 }]}
            data-filter={c}
          >
            {c}
          </button>
        ))
      }
    </div>

    <div class="tools-grid" id="tools-grid">
      {
        tools.map((t) => (
          <a
            href={t.data.url}
            target="_blank"
            rel="noopener noreferrer"
            class="tool-card"
            data-category={t.data.category}
          >
            <div class="tool-top">
              <span class="tool-cat">{t.data.category}</span>
              <span class:list={["tool-price", pricingClass[t.data.pricing]]}>
                {t.data.pricing}
              </span>
            </div>
            <h3 class="tool-name">{t.data.name}</h3>
            <p class="tool-desc">{t.data.description}</p>
            <div class="tool-foot">
              {t.data.inBulgarian && <span class="tool-bg">✓ на български</span>}
              <span class="tool-go">Отвори →</span>
            </div>
          </a>
        ))
      }
    </div>
  </main>
</Layout>

<style>
  .page {
    padding-top: 52px;
    padding-bottom: 80px;
  }
  .page-title {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 46px;
    letter-spacing: -0.02em;
    margin: 14px 0 12px;
  }
  .page-lead {
    font-family: var(--serif);
    font-size: 18px;
    color: var(--body);
    margin: 0 0 34px;
    max-width: 40em;
  }
  .filters {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 30px;
    border-top: 1px solid var(--ink);
    padding-top: 24px;
  }
  .filter-btn {
    cursor: pointer;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    padding: 8px 14px;
    border: 1px solid var(--ink);
    background: transparent;
    color: var(--ink);
    transition: all 0.12s ease;
  }
  .filter-btn.active {
    background: var(--ink);
    color: var(--cream);
  }
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  .tool-card {
    display: flex;
    flex-direction: column;
    background: var(--panel-cream);
    padding: 26px;
    min-height: 200px;
    text-decoration: none;
    transition: background 0.12s ease;
  }
  .tool-card:hover {
    background: #fff;
  }
  .tool-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }
  .tool-cat {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .tool-price {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 8px;
    border: 1px solid var(--line);
  }
  .tool-price.free {
    color: #3f7a52;
    border-color: #3f7a52;
  }
  .tool-price.freemium {
    color: var(--accent);
    border-color: var(--accent);
  }
  .tool-price.paid {
    color: var(--muted);
    border-color: var(--muted);
  }
  .tool-name {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 24px;
    line-height: 1.15;
    color: var(--ink);
    margin: 0 0 10px;
  }
  .tool-desc {
    font-size: 14px;
    line-height: 1.55;
    color: var(--body-2);
    margin: 0 0 18px;
  }
  .tool-foot {
    margin-top: auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.04em;
  }
  .tool-bg {
    color: #3f7a52;
  }
  .tool-go {
    color: var(--accent);
    font-weight: 600;
    margin-left: auto;
  }
  @media (max-width: 900px) {
    .tools-grid {
      grid-template-columns: 1fr;
    }
    .page-title {
      font-size: 34px;
    }
  }
</style>

<script>
  function initToolFilters() {
    const filterWrap = document.getElementById("filters");
    if (!filterWrap || filterWrap.dataset.bound) return;
    filterWrap.dataset.bound = "1";

    const buttons =
      filterWrap.querySelectorAll<HTMLButtonElement>(".filter-btn");
    const cards = document.querySelectorAll<HTMLElement>(".tool-card");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const filter = btn.dataset.filter!;
        buttons.forEach((b) => b.classList.toggle("active", b === btn));
        cards.forEach((card) => {
          const show =
            filter === "Всички" || card.dataset.category === filter;
          card.style.display = show ? "" : "none";
        });
      });
    });
  }

  initToolFilters();
  document.addEventListener("astro:page-load", initToolFilters);
</script>
